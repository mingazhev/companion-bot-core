# ============================================================
# TdBot — environment variable template
# ============================================================
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to version control.
# All secrets must be provided via environment variables at
# runtime; no hardcoded tokens exist anywhere in the codebase.
# ============================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# Webhook mode: set to your HTTPS public hostname, e.g. https://example.com
# Leave empty to use long-polling (dev default).
TELEGRAM_WEBHOOK_HOST=
TELEGRAM_WEBHOOK_PATH=/webhook

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://tdbot:password@localhost:5432/tdbot
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- OpenAI / model provider ---
OPENAI_API_KEY=sk-...
CHAT_MODEL=gpt-4o-mini
REFINEMENT_MODEL=gpt-4o
# Override to use a compatible proxy (optional):
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Rate limits ---
RATE_LIMIT_MESSAGES_PER_MINUTE=20
RATE_LIMIT_GLOBAL_RPS=100

# --- Data retention ---
# TTL for conversation_messages rows, in seconds (default: 7 days)
CONVERSATION_TTL_SECONDS=604800

# --- Refinement worker ---
REFINEMENT_CADENCE_SECONDS=3600
REFINEMENT_ACTIVITY_THRESHOLD=5

# --- Observability ---
LOG_LEVEL=INFO
# 'json' for production; 'console' for local development
LOG_FORMAT=console
SERVICE_NAME=tdbot
ENVIRONMENT=local

# --- Field-level encryption ---
ENCRYPT_SENSITIVE_FIELDS=false
# 32-byte Fernet key (base64url-encoded). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required when ENCRYPT_SENSITIVE_FIELDS=true. Starting without it raises RuntimeError.
FIELD_ENCRYPTION_KEY=

# --- Local development ---
# Set to true to replace the real OpenAI client with FakeChatAPIClient so the
# full pipeline (ingress → detector → prompt manager → model adapter → persistence)
# runs locally without valid API credentials.
# NEVER enable in production — all model calls return deterministic fake responses.
USE_FAKE_ADAPTERS=false

# --- Internal HTTP service ---
# Bind address and port for the internal API (/internal/refine, /internal/detect-change)
# and the Prometheus /metrics endpoint. Keep on loopback — do NOT expose externally.
INTERNAL_SERVER_HOST=127.0.0.1
INTERNAL_SERVER_PORT=8080
