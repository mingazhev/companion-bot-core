# Docker image to run (GitHub Actions updates IMAGE_TAG automatically)
IMAGE_NAME=ghcr.io/mingazhev/companion-bot-core
IMAGE_TAG=latest

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_HOST=
TELEGRAM_WEBHOOK_PATH=/webhook

# PostgreSQL container credentials
POSTGRES_DB=companion_bot_core
POSTGRES_USER=companion_bot_core
POSTGRES_PASSWORD=change-me-strong-password

# Application DB/Redis URLs (inside docker network)
DATABASE_URL=postgresql+asyncpg://companion_bot_core:change-me-strong-password@postgres:5432/companion_bot_core
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
REDIS_URL=redis://redis:6379/0

# OpenAI / model provider
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-4o-mini
REFINEMENT_MODEL=gpt-4o

# Rate limits
RATE_LIMIT_MESSAGES_PER_MINUTE=20
RATE_LIMIT_GLOBAL_RPS=100

# Retention
CONVERSATION_TTL_SECONDS=604800

# Refinement worker
REFINEMENT_CADENCE_SECONDS=3600
REFINEMENT_ACTIVITY_THRESHOLD=5

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=json
SERVICE_NAME=companion_bot_core
ENVIRONMENT=production

# Internal HTTP service (must stay loopback)
INTERNAL_SERVER_HOST=127.0.0.1
INTERNAL_SERVER_PORT=8080

# Security
ENCRYPT_SENSITIVE_FIELDS=false
FIELD_ENCRYPTION_KEY=

# Never enable fake adapters in production
USE_FAKE_ADAPTERS=false
